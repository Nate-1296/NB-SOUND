# NB SOUND - ejemplo de configuracion operativa.
# Copia este archivo a .env y ajusta rutas/credenciales locales.
# La UI guarda preferencias en config_ui dentro de la DB y, si ya existen,
# esos valores tienen prioridad sobre .env para importaciones lanzadas desde UI.

# Rutas canonicas. CLI y UI usan USER_LIBRARY_DIR/nb_sound.sqlite3 como DB.
USER_INPUT_DIR=
USER_LIBRARY_DIR=
USER_QUARANTINE_DIR=
USER_REVIEW_DIR=
USER_LOGS_DIR=
USER_PROCESSED_DIR=
USER_CACHE_DIR=
USER_TEMP_DIR=
USER_ASSETS_DIR=
USER_MANIFESTS_DIR=

# Identificacion externa opcional.
ACOUSTID_API_KEY=
ENABLE_ACOUSTID=True
ENABLE_SHAZAM=True
SHAZAM_TIMEOUT_SEG=12
SHAZAM_MIN_DURACION_SEG=20

# IA externa para desempate/catalogacion. No es Audio Intelligence local.
IA_PROVEEDOR=No
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ENABLE_IA_TIEBREAK=True
IA_TIEBREAK_MIN_GAP=0.12
IA_MAX_TOKENS=512
IA_TIMEOUT_SEG=20
ENABLE_IA_DISCOGRAPHY=True
DISCOGRAPHY_IA_MIN_CONFIDENCE=0.90

# Operacion del pipeline principal.
SKIP_ALREADY_PROCESSED=False
INIT_COMPONENT_MAX_RETRIES=2
INIT_COMPONENT_RETRY_BACKOFF_SEG=0.7
ENABLE_DEDUPLICATION=True
ENABLE_SEMANTIC_DEDUPLICATION=True
DUPLICATE_POLICY=replace_if_better
DUPLICATE_BETTER_MIN_DELTA=0.08

# Progreso, sidecars y observabilidad.
NB_SOUND_PROGRESS_MODE=auto
NB_SOUND_PROGRESS_INTERVAL_SEC=2.0
SIDECAR_FUTURE_TIMEOUT_SEG=90.0
SIDECAR_WAIT_HEARTBEAT_SEG=2.0

# Assets visuales: portadas de pista/album e imagenes de artista.
ENABLE_ASSETS_PIPELINE=True
ENABLE_COVER_ART_ARCHIVE=True
ENABLE_THEAUDIODB_ARTIST_IMAGES=True
ENABLE_ITUNES_COVER_FALLBACK=True
ENABLE_DEEZER_ARTIST_IMAGES=True
ENABLE_WIKIPEDIA_ARTIST_IMAGES=True
ENABLE_ITUNES_ARTIST_IMAGES=True
THEAUDIODB_API_KEY=123
ASSETS_TIMEOUT_SEG=10
ASSETS_MAX_RETRIES=2
ASSETS_RETRY_BACKOFF_SEG=0.8
ASSETS_CACHE_TTL_SEG=259200
ASSETS_NEGATIVE_CACHE_TTL_SEG=21600
ASSETS_MIN_RESOLUTION=250
ASSETS_HD_MAX_IMAGE_BYTES=25000000

# Enrichment externo: lyrics y analitica auxiliar. No debe bloquear importacion.
ENABLE_EXTERNAL_ENRICHMENT=True
ENABLE_LYRICS_ENRICHMENT=True
ENABLE_LRCLIB=True
ENABLE_LYRICS_OVH=True
LYRICS_TIMEOUT_SEG=8
LYRICS_MAX_RETRIES=1
LYRICS_RETRY_BACKOFF_SEG=0.8
LYRICS_SUGGEST_LIMIT=3

# Fases conservadoras y manifiestos.
ENABLE_SECOND_STAGE_RESOLUTION=True
SECOND_STAGE_MAX_CANDIDATES=5
SECOND_STAGE_MIN_EVIDENCE=0.86
SECOND_STAGE_MIN_GAP=0.12
SECOND_STAGE_CAUSE_ENABLED=True
ENABLE_THIRD_STAGE_RESOLUTION=True
THIRD_STAGE_MIN_EVIDENCE=0.90
THIRD_STAGE_MIN_GAP=0.14
MANIFEST_SCHEMA_VERSION=1
ENABLE_OVERRIDES=True

# Audio Features local basico con librosa. Ligero y apto para Music Discovery.
ENABLE_AUDIO_FEATURES=True
AUDIO_FEATURES_MODE=light
AUDIO_FEATURES_ANALYZE_ON_IMPORT=True
AUDIO_FEATURES_BACKGROUND=True
AUDIO_FEATURES_MAX_WORKERS=1
AUDIO_FEATURES_ANALYZE_FULL_TRACK=False
AUDIO_FEATURES_SAMPLE_STRATEGY=smart_segments
AUDIO_FEATURES_SEGMENT_SECONDS=90
AUDIO_FEATURES_REANALYZE_ON_VERSION_CHANGE=True
AUDIO_FEATURES_FAIL_SILENTLY=True

# Audio Intelligence profunda local con modelos Essentia/TensorFlow.
# Seguro por defecto: desactivado y sin backend pesado.
ENABLE_AUDIO_INTELLIGENCE_DEEP=False
AUDIO_INTELLIGENCE_BACKEND=none
ENABLE_AUDIO_MOOD_MODELS=False
ENABLE_AUDIO_EMBEDDINGS=False
ENABLE_AUDIO_TAGGING_MODELS=False
AUDIO_INTELLIGENCE_MODEL_DIR=
# Ejemplo local, no activar sin modelos descargados:
# AUDIO_INTELLIGENCE_MODEL_DIR=/ruta/a/modelos_essentia
AUDIO_INTELLIGENCE_ANALYZE_ON_IMPORT=False
AUDIO_INTELLIGENCE_ANALYZE_AFTER_IMPORT_BACKGROUND=True
AUDIO_INTELLIGENCE_RESUME_PENDING_ON_STARTUP=True
AUDIO_INTELLIGENCE_BACKGROUND_AUTOSTART=True
AUDIO_INTELLIGENCE_BACKGROUND=True
AUDIO_INTELLIGENCE_MAX_WORKERS=1
AUDIO_INTELLIGENCE_BACKGROUND_BATCH_SIZE=1
AUDIO_INTELLIGENCE_BACKGROUND_IDLE_DELAY_SEC=2
AUDIO_INTELLIGENCE_BACKGROUND_MAX_RUNTIME_MIN=0
AUDIO_INTELLIGENCE_ALLOW_MODEL_DOWNLOADS=False
AUDIO_INTELLIGENCE_SAMPLE_STRATEGY=smart_segments
AUDIO_INTELLIGENCE_SEGMENT_SECONDS=120
AUDIO_INTELLIGENCE_REANALYZE_ON_MODEL_CHANGE=True
AUDIO_INTELLIGENCE_RETRY_FAILED=False
AUDIO_INTELLIGENCE_MAX_ATTEMPTS=1
AUDIO_INTELLIGENCE_CANCEL_DISCARD_OUTPUTS=False
AUDIO_INTELLIGENCE_FAIL_SILENTLY=True

# Music Discovery: busqueda musical natural sobre features locales.
ENABLE_MUSIC_DISCOVERY=True
MUSIC_DISCOVERY_USE_AUDIO_FEATURES=True
MUSIC_DISCOVERY_USE_DEEP_FEATURES=True
MUSIC_DISCOVERY_MIN_CONFIDENCE=0.35
MUSIC_DISCOVERY_DEFAULT_LIMIT=25
MUSIC_DISCOVERY_EXPLAIN_RESULTS=True
