[Desktop Entry]
Type=Application
Name=NB SOUND
GenericName=Music library manager
Comment=Catalogador inteligente de bibliotecas de audio
Exec=/usr/local/bin/nb-sound
Icon=nb-sound
Terminal=false
Categories=AudioVideo;Audio;Music;Player;
Keywords=music;audio;library;tagger;
StartupNotify=true
# Asocia la ventana ABIERTA con este .desktop para que el panel/dock muestre el
# icono de la app y no uno genérico. Debe coincidir con el app_id que Qt fija
# vía setDesktopFileName("nb-sound") en main_ui.py.
StartupWMClass=nb-sound
